# Backend API base for fetch() from the browser (and SSR). See apps/web/app/config.ts:
# If unset, defaults to http://localhost:8000 (typical local backend on the same machine).
#
# Docker Compose: docker-compose.yml sets NEXT_PUBLIC_API_BASE=http://localhost:8000 so the
# browser on your host reaches the API port published on the host (not the backend service name).
#
# Phone on same Wi-Fi: NEXT_PUBLIC_API_BASE=http://YOUR_COMPUTER_IP:8000
# NEXT_PUBLIC_API_BASE=http://localhost:8000
