# Backend API base URL. Used only on the server (SSR). In the browser the app uses same host + :8000.
# Local dev (no Docker): optional; leave empty or set to http://localhost:8000 for SSR.
# Docker: set in docker-compose to http://backend:8000 so the frontend container can reach the API.
# NEXT_PUBLIC_API_BASE=http://localhost:8000
# NEXT_PUBLIC_API_BASE=http://backend:8000
