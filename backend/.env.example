# Database: Postgres only. Required.
# Local: postgresql+asyncpg://cooking:cooking@127.0.0.1:5432/cooking
# Docker: postgresql+asyncpg://cooking:cooking@postgres:5432/cooking
DATABASE_URL=postgresql+asyncpg://cooking:cooking@127.0.0.1:5432/cooking

# AWS RDS and some managed Postgres require TLS. Set true when the server expects SSL.
# DATABASE_SSL=true

# Auth: long random string for JWT signing (e.g. openssl rand -hex 32). Required for /auth/register and /auth/login.
AUTH_SECRET=your-secret-at-least-16-chars

# CORS: comma-separated origins (e.g. frontend URL). Do not use * with credentials.
# Dev: http://localhost:3000,http://127.0.0.1:3000
# Prod (cross-origin): https://cook-lake-alpha.vercel.app
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Auth cookie: for cross-origin (frontend on Vercel, API on api.chef-world.com) set both so login persists.
# COOKIE_SAMESITE=none requires COOKIE_SECURE=true.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# OpenAI API key for recipe extraction and shopping-list refine (LLM).
# Without this, the app uses stub extraction so you can still test the flow.
OPENAI_API_KEY=sk

# Recipe image uploads: leave both empty for local dev (files saved under ./uploads, served at /uploads/...).
# Set both for S3 presigned browser uploads in production.
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=your-bucket-name

# Optional override for local disk uploads (default: ./uploads relative to backend cwd).
# LOCAL_IMAGE_UPLOAD_DIR=uploads

# Optional: restrict who can publish recipes into the shared public catalog.
# If left empty, local dev stays open for testing, while non-local deployments fall back to:
#   jerryxiang24@gmail.com
# To override explicitly in any environment:
# PUBLIC_LIBRARY_EDITOR_EMAILS=jerryxiang24@gmail.com
